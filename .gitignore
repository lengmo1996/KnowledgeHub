# Python
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/
.coverage
.coverage.*
htmlcov/
build/
dist/

# Virtual environments and local secrets
.venv/
venv/
.env
.env.*
!.env.example

# Editors and operating systems
.idea/
.vscode/
.DS_Store
*.tmp
*.temp
*.bak
*~
*.swp
*.swo
*.pid

# Additional local test and tool outputs
coverage.xml
.hypothesis/
.tox/
.nox/
.cache/

# KnowledgeHub runtime state must stay outside the repository.
/data/
/state/
!/state/
!/state/releases/
!/state/releases/v1_manifest.json
# V3 fixture workspaces, run records, locks, and cleanup manifests are reproducible runtime data.
/state/fixtures/
/raw/
/extracted/
/manifests/
/runs/
/logs/
*.sqlite
*.sqlite3
*.sqlite3-*
*.db
*.log
*.parquet
/benchmarks/
/model-cache/
/qdrant/
/parsed/
/chunks/
/failures/
/snapshots/
/sources/
/normalized/
/derived/
/indexes/

# Explicitly supplied Personal Writing Profile drafts stay local.
/personal-writing-profile*.md

# Zotero/WebDAV and extracted binary payloads are never source artifacts.
*.zip
*.prop
*.pdf
