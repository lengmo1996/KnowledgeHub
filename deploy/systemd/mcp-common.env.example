KH_MCP_TOKEN_FILE=/etc/knowledgehub/mcp-tokens.json
KH_MCP_TOKEN_HMAC_KEY=replace-with-at-least-32-random-characters
KH_MCP_ZOTERO_STATE_PATH=/data/KnowledgeHub/zotero/state/zotero.sqlite3
KH_MCP_REQUEST_TIMEOUT_SECONDS=120
KH_MCP_SESSION_IDLE_SECONDS=900
KH_MCP_MAX_RESPONSE_BYTES=1048576
KH_MCP_MAX_CONCURRENT_REQUESTS=8
KH_MCP_REQUESTS_PER_MINUTE=60
