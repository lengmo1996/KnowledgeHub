# Copy only the values you need into an external environment file.
# KnowledgeHub does not automatically load .env files. Never commit a real key.
ZOTERO_API_KEY=
ZOTERO_LIBRARY_TYPE=user
# Required for group libraries. For user libraries it may be left empty and is
# then derived from /keys/current; an explicit value must match the key owner.
ZOTERO_LIBRARY_ID=
ZOTERO_API_BASE_URL=https://api.zotero.org

# The WebDAV directory is a read-only input. DATA_DIR holds all writable state.
ZOTERO_WEBDAV_DIR=/data/KnowledgeHub/zotero_cache
ZOTERO_DATA_DIR=/data/KnowledgeHub/zotero

ZOTERO_HTTP_TIMEOUT_SECONDS=30
ZOTERO_MAX_RETRIES=5
ZOTERO_SYNC_MAX_RETRIES=3
ZOTERO_API_CONCURRENCY=2

ZOTERO_ZIP_STABILITY_INTERVAL_SECONDS=10
ZOTERO_ZIP_STABILITY_CHECK_COUNT=2
ZOTERO_MAPPING_VALIDATION_SAMPLE_SIZE=20
ZOTERO_ATTACHMENT_SCAN_ON_304=true
ZOTERO_METADATA_CHANGES_REQUIRE_CHUNKING=false

# Streaming is intentionally unavailable in v1. Keep this false and use the
# systemd timer or the watch command for polling.
ZOTERO_ENABLE_STREAMING=false
ZOTERO_POLL_INTERVAL_SECONDS=300
ZOTERO_LOG_LEVEL=INFO

# Unified RAG pipeline. Secrets remain external and are never loaded
# automatically by KnowledgeHub.
KH_ZOTERO_SNAPSHOT_PATH=/data/KnowledgeHub/zotero/manifests/documents.jsonl
KH_ZOTERO_DELTA_CATALOG_PATH=/data/KnowledgeHub/zotero/manifests/delta-catalog.jsonl
KH_RAG_DATA_DIR=/data/KnowledgeHub/rag/zotero
KH_QDRANT_URL=http://127.0.0.1:6333
KH_QDRANT_COLLECTION=zotero_papers_qwen3_4b_1024_v2
KH_QDRANT_SMOKE_COLLECTION=zotero_papers_qwen3_4b_1024_smoke
KH_MODEL_CACHE_DIR=/data/KnowledgeHub/model-cache

KH_GPU_MODE=auto
KH_GPU_IDS=0,1
KH_PARSE_GPU_IDS=0,1
KH_EMBED_ENDPOINTS=http://127.0.0.1:8080,http://127.0.0.1:8082
KH_EMBED_REQUEST_STRATEGY=least_outstanding
KH_EMBEDDING_TIMEOUT_SECONDS=120
KH_RERANK_GPU_ID=1
KH_RERANKER_PROFILE=off
KH_RERANKER_URL=http://127.0.0.1:8081

KH_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
KH_EMBEDDING_REVISION=5cf2132abc99cad020ac570b19d031efec650f2b
KH_EMBEDDING_DIM=1024
KH_SEARCH_API_KEY=
KH_RERANKER_API_KEY=
KH_SPARSE_MODEL=Qdrant/bm25
