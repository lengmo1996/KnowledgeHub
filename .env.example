# Copy only the values you need into an external environment file.
# KnowledgeHub does not automatically load .env files. Never commit a real key.
ZOTERO_API_KEY=
ZOTERO_LIBRARY_TYPE=user
# Required for group libraries. For user libraries it may be left empty and is
# then derived from /keys/current; an explicit value must match the key owner.
ZOTERO_LIBRARY_ID=
ZOTERO_API_BASE_URL=https://api.zotero.org

# Nutstore WebDAV application credentials. Use the account name and the
# application password generated by Nutstore; never put them in YAML or a unit.
ZOTERO_WEBDAV_URL=https://dav.jianguoyun.com/dav/zotero/
ZOTERO_WEBDAV_USERNAME=
ZOTERO_WEBDAV_PASSWORD=
ZOTERO_WEBDAV_PAGE_LIMIT=10000
# Minimum delay between WebDAV request starts; 0 disables client-side pacing.
ZOTERO_WEBDAV_REQUEST_INTERVAL_SECONDS=2.0

# refresh-cache owns this disposable mirror. The source resolver reads it only
# after refresh-cache exits. DATA_DIR holds durable KnowledgeHub state.
ZOTERO_WEBDAV_DIR=/data/KnowledgeHub/zotero_cache
ZOTERO_DATA_DIR=/data/KnowledgeHub/zotero

ZOTERO_HTTP_TIMEOUT_SECONDS=30
ZOTERO_MAX_RETRIES=5
ZOTERO_SYNC_MAX_RETRIES=3
ZOTERO_API_CONCURRENCY=2

ZOTERO_ZIP_STABILITY_INTERVAL_SECONDS=10
ZOTERO_ZIP_STABILITY_CHECK_COUNT=2
ZOTERO_MAPPING_VALIDATION_SAMPLE_SIZE=20
ZOTERO_ATTACHMENT_SCAN_ON_304=true
ZOTERO_METADATA_CHANGES_REQUIRE_CHUNKING=false

# Streaming is intentionally unavailable in v1. Keep this false and use the
# systemd timer or the watch command for polling.
ZOTERO_ENABLE_STREAMING=false
ZOTERO_POLL_INTERVAL_SECONDS=300
ZOTERO_LOG_LEVEL=INFO

# Unified RAG pipeline. Secrets remain external and are never loaded
# automatically by KnowledgeHub.
KH_ZOTERO_SNAPSHOT_PATH=/data/KnowledgeHub/zotero/manifests/documents.jsonl
KH_ZOTERO_DELTA_CATALOG_PATH=/data/KnowledgeHub/zotero/manifests/delta-catalog.jsonl
KH_RAG_DATA_DIR=/data/KnowledgeHub/rag/zotero
KH_QDRANT_URL=http://127.0.0.1:6333
KH_QDRANT_COLLECTION=zotero_papers_qwen3_4b_1024_v2
KH_QDRANT_SMOKE_COLLECTION=zotero_papers_qwen3_4b_1024_smoke
KH_QDRANT_UPSERT_BATCH_SIZE=32
KH_MODEL_CACHE_DIR=/data/KnowledgeHub/model-cache

KH_GPU_MODE=auto
KH_GPU_IDS=0,1
KH_PARSE_GPU_IDS=0,1
# Daily systemd scheduler: only claim cards that are effectively idle before
# starting temporary embedding containers. Failure retries after 4 hours.
KH_RAG_SCHEDULER_GPU_IDS=0,1
KH_RAG_SCHEDULER_MIN_FREE_MB=20000
KH_RAG_SCHEDULER_MAX_USED_MB=1024
KH_RAG_RETRY_DELAY_SECONDS=14400
KH_EMBED_ENDPOINTS=http://127.0.0.1:8080,http://127.0.0.1:8082
KH_EMBED_REQUEST_STRATEGY=least_outstanding
KH_EMBEDDING_TIMEOUT_SECONDS=120
KH_RERANK_GPU_ID=1
KH_RERANKER_PROFILE=off
KH_RERANKER_URL=http://127.0.0.1:8081

KH_EMBEDDING_MODEL=Qwen/Qwen3-Embedding-4B
KH_EMBEDDING_REVISION=5cf2132abc99cad020ac570b19d031efec650f2b
KH_EMBEDDING_DIM=1024
KH_EMBEDDING_API_KEY=
# Locally generated, independent 32-byte bearer tokens; they are not vendor keys.
# Generate each value separately with: openssl rand -hex 32
KH_SEARCH_API_KEY=
KH_RERANKER_API_KEY=
KH_SPARSE_MODEL=Qdrant/bm25

# Multi-knowledge-base catalog and optional authenticated GitHub API access.
KH_HUB_CONFIG=/home/user/KnowledgeHub/configs/knowledgehub.yaml
GITHUB_TOKEN=

# Read-only MCP. Put real values in /etc/knowledgehub/mcp-*.env with mode 0600.
# LAN unit: lan / 10.249.44.27 / 8091. Tailscale unit: tailscale / 127.0.0.1 / 8092.
KH_MCP_LISTENER=tailscale
KH_MCP_HOST=127.0.0.1
KH_MCP_PORT=8092
KH_MCP_PUBLIC_URL=https://server-ai-00.tail02a76b.ts.net/mcp
KH_MCP_ALLOWED_HOSTS=127.0.0.1:8092,server-ai-00.tail02a76b.ts.net
KH_MCP_ALLOWED_ORIGINS=
KH_MCP_TOKEN_FILE=/etc/knowledgehub/mcp-tokens.json
# Generate outside Git, for example: openssl rand -base64 48
KH_MCP_TOKEN_HMAC_KEY=
KH_MCP_ZOTERO_STATE_PATH=/data/KnowledgeHub/zotero/state/zotero.sqlite3
KH_MCP_REQUEST_TIMEOUT_SECONDS=120
KH_MCP_SESSION_IDLE_SECONDS=900
KH_MCP_MAX_RESPONSE_BYTES=1048576
KH_MCP_MAX_CONCURRENT_REQUESTS=8
KH_MCP_MAX_CONCURRENT_EMBEDDINGS=2
KH_MCP_MAX_CONCURRENT_RERANKERS=1
KH_MCP_REQUESTS_PER_MINUTE=60
KH_MCP_AUDIT_LOG=/var/log/knowledgehub/mcp-tailscale-audit.jsonl
